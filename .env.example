# =============================================================================
# personal-ai-os — environment variables (EXAMPLE)
# Copy to ~/.hermes/.env on your VPS, fill in real values, chmod 600.
# NEVER commit the real .env. Every value below is a placeholder.
# Only set the keys for the components you actually enable.
# =============================================================================

# --- LLM: DeepSeek (primary, cheap, OpenAI-compatible) -----------------------
# Get a key at https://platform.deepseek.com  → API keys
DEEPSEEK_API_KEY=sk-deepseek-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Vision (image understanding) via OpenRouter -----------------------------
# Only needed if you want the agent to understand images.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Channels: Telegram ------------------------------------------------------
# Create a bot via @BotFather, then find your numeric chat id (e.g. via @userinfobot)
TELEGRAM_BOT_TOKEN=0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_HOME_CHANNEL=<your_numeric_chat_id>
TELEGRAM_HOME_CHANNEL_NAME=Me

# --- Channels: Slack ---------------------------------------------------------
# Create an app at https://api.slack.com/apps (Socket Mode + bot token)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-x-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_ALLOWED_USERS=<your_slack_user_id>

# --- Web search & extraction: Tavily -----------------------------------------
# Free tier at https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# --- YouTube transcript fallback: Apify (optional) ---------------------------
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Calendar: Apple iCloud (CalDAV) -----------------------------------------
# Apple ID + an app-specific password from https://appleid.apple.com
ICLOUD_USERNAME=you@example.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Tasks: Google Tasks (OAuth) ---------------------------------------------
# Create an OAuth client in Google Cloud Console; consent screen in "Production"
# so the refresh token does not expire after 7 days.
GOOGLE_TASKS_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_TASKS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_TASKS_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx

# --- n8n monitoring (optional) -----------------------------------------------
N8N_API_URL=https://n8n.example.com/api/v1
N8N_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Self-improvement: Claude Code on the VPS (optional) ---------------------
# From `claude setup-token` with your Claude plan.
CLAUDE_CODE_OAUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Dashboard ingest (optional) ---------------------------------------------
# The VPS pushes the daily briefing JSON to your Vercel dashboard.
DASHBOARD_INGEST_URL=https://<your-dashboard>.vercel.app/api/ingest
DASHBOARD_INGEST_SECRET=<long_random_string>

# Note: mail (T-Online/IMAP) and the Brevo SMTP relay use separate files on the
# VPS, not env vars: ~/.hermes/.tonline_pass and ~/.hermes/.brevo_pass (chmod 600).
# See docs/07-mail.md.
